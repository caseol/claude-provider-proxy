# perfil openrouter/qwen — família Qwen3 via OpenRouter
# qwen3.7-max (flagship) nos tiers altos; qwen3.7-plus como workhorse;
# qwen3.6-flash no tier rápido. Todos com ~1M de contexto.
FABLE_MODEL=qwen/qwen3.7-max
OPUS_MODEL=qwen/qwen3.7-max
SONNET_MODEL=qwen/qwen3.7-plus
HAIKU_MODEL=qwen/qwen3.6-flash
SUBAGENT_MODEL=qwen/qwen3.7-plus
