# perfil openrouter/kimi — família Kimi (Moonshot AI) via OpenRouter
# k2.7-code (mais novo, coding-oriented) nos tiers altos; k2.5 como workhorse;
# k2 (base, menor ctx) no tier rápido. kimi-k2.6 evitado de propósito: corrompe
# tool calls quando servido via NIM — não usar com tools até verificar
# separadamente que o OpenRouter não tem a mesma regressão.
FABLE_MODEL=moonshotai/kimi-k2.7-code
OPUS_MODEL=moonshotai/kimi-k2.7-code
SONNET_MODEL=moonshotai/kimi-k2.5
HAIKU_MODEL=moonshotai/kimi-k2
SUBAGENT_MODEL=moonshotai/kimi-k2.5
